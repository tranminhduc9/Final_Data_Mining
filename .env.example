# ============================================================
# APP / golang-api
# ============================================================
APP_ENV=development
PORT=8080
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8081
JWT_SECRET=jwt_secret_placeholder
PYTHON_AI_BASE_URL=http://localhost:8000   # local dev; docker compose override -> http://rag-service:8000
PYTHON_ML_CLUSTERING_BASE_URL=http://localhost:8001   # local dev; docker compose override -> http://ml-clustering:8001

# ============================================================
# POSTGRESQL — Render cloud (cả 2 service dùng chung)
# ============================================================
PostgreSQL_CONNECTION_STRING=postgresql://postgres_user_placeholder:postgres_password_placeholder@postgres_host_placeholder/postgres_db_placeholder?sslmode=require

# RAG service đọc dạng tách rời (xem app/config.py)
POSTGRES_HOST=postgres_host_placeholder
POSTGRES_PORT=5432
POSTGRES_DB=postgres_db_placeholder
POSTGRES_USER=postgres_user_placeholder
POSTGRES_PASSWORD=postgres_password_placeholder

# ============================================================
# NEO4J — AuraDB (cloud)
# ============================================================
NEO4J_URI=neo4j_uri_placeholder
NEO4J_USERNAME=neo4j_username_placeholder
NEO4J_PASSWORD=neo4j_password_placeholder
NEO4J_DATABASE=neo4j_database_placeholder

# ============================================================
# NEO4J — Local (chỉ dùng khi USE_LOCAL_NEO4J=true)
# ============================================================
NEO4J_LOCAL_URI=neo4j_local_uri_placeholder
NEO4J_LOCAL_USERNAME=neo4j
NEO4J_LOCAL_PASSWORD=localpassword
USE_LOCAL_NEO4J=false

# ============================================================
# LLM — Gemini
# ============================================================
GEMINI_API_KEY=gemini_api_key_placeholder

# ============================================================
# REDIS / EMBED
# ============================================================
REDIS_URL=redis://localhost:6379
EMBED_SECRET=embed_secret_placeholder

# ============================================================
# LANGSMITH (optional, để trace RAG pipeline)
# ============================================================
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your_langsmith_key_here
LANGCHAIN_PROJECT=techpulse-rag


# ============================================================
# OPENAI
# ============================================================
OPENAI_API_KEY=openai_api_key_placeholder
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

# ============================================================
# ml-clustering — S3 artifacts (snapshot parquet + cluster_labels.json)
# ============================================================
MLCLUSTER_S3_BUCKET=cluster-rag-kpdl
MLCLUSTER_S3_PREFIX=ml-clustering
MLCLUSTER_S3_REGION=ap-southeast-1
MLCLUSTER_S3_CACHE_DIR=/tmp/ml-clustering-cache
MLCLUSTER_S3_ACCESS_KEY_ID=S3_access_key_id_placeholder
MLCLUSTER_S3_SECRET_ACCESS_KEY=S3_secret_access_key_placeholder

MLCLUSTER_SNAPSHOT_TAG=latest
MLCLUSTER_S3_MANIFEST_KEY=latest.json
MLCLUSTER_RELOAD_TTL_SECONDS=300