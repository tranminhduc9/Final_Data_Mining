# ============================================================
# NEO4J — AuraDB (cloud, dùng khi deploy hoặc export data)
# ============================================================
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_aura_password_here

# ============================================================
# NEO4J — Local (dùng khi dev trên máy)
# ============================================================
NEO4J_LOCAL_URI=bolt://localhost:7687
NEO4J_LOCAL_USERNAME=neo4j
NEO4J_LOCAL_PASSWORD=localpassword

# ============================================================
# GEMINI
# ============================================================
GEMINI_API_KEY=your_gemini_api_key_here

# ============================================================
# POSTGRESQL
# ============================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=techpulse
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ============================================================
# REDIS
# ============================================================
REDIS_URL=redis://localhost:6379

# ============================================================
# LANGSMITH (optional, để trace RAG pipeline)
# ============================================================
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your_langsmith_key_here
LANGCHAIN_PROJECT=techpulse-rag

# ============================================================
# EMBED TRIGGER — secret để crawler gọi POST /embed/trigger
# ============================================================
EMBED_SECRET=your_random_secret_here
